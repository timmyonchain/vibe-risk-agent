# ─────────────────────────────────────────────────────────────
# Vibe Risk Agent — Environment Variables (TEMPLATE)
#
# HOW TO USE:
#   1. Copy this file and rename the copy to ".env.local"
#   2. Paste your REAL keys after the "=" signs in .env.local
#   3. Never commit .env.local — it is already in .gitignore
#
# This .example file is safe to commit: it has NO real secrets.
# ─────────────────────────────────────────────────────────────

# Groq — powers the AI decision-making (get a key at https://console.groq.com)
GROQ_API_KEY=

# Bitget API credentials (only needed for authenticated/account calls).
# Public market data does NOT require these. We use paper trading only —
# no real funds are ever traded.
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=
